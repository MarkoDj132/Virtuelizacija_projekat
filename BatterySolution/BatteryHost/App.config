<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<add key="V_threshold" value="0.001"/>
		<add key="Z_threshold" value="0.01"/>
	</appSettings>
	<system.serviceModel>
		<services>
			<service name ="BatteryService.BatteryService">

				<endpoint address=""
						  binding="netTcpBinding"
						  contract="Common.Contracts.IBatteryService"/>

				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:9000/BatteryService"/>
					</baseAddresses>
				</host>
			</service>
		</services>
	</system.serviceModel>
</configuration>